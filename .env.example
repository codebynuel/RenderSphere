# RenderSphere gateway runtime
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rendersphere?schema=public"

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"

# RunPod
RUNPOD_ENDPOINT_ID="your_runpod_endpoint_id"
RUNPOD_API_KEY="your_runpod_api_key"
R2_ENDPOINT="https://your_cloudflare_account_id.r2.cloudflarestorage.com"

# App behavior
RENDERSPHERE_PUBLIC_URL="http://localhost:3000"
RENDERSPHERE_SUPPORT_EMAIL="support@rendersphere.app"
RENDERSPHERE_RENDER_PRICE_PER_SECOND_USD=0.01
RENDERSPHERE_FREE_RENDER_CREDITS_USD=0
RENDERSPHERE_MIN_RENDER_START_BALANCE_USD=1.00
RENDERSPHERE_SECURE_COOKIES=false
RENDERSPHERE_JOB_POLL_INTERVAL_MS=5000

# Limits
RENDERSPHERE_MAX_UPLOAD_MB=10240
RENDERSPHERE_MAX_RENDER_SAMPLES=2048
RENDERSPHERE_MAX_RESOLUTION_PCT=150
RENDERSPHERE_MAX_ANIMATION_FRAMES=250
RENDERSPHERE_MAX_CONCURRENT_JOBS=1
RENDERSPHERE_MAX_QUEUED_JOBS=3
RENDERSPHERE_JOB_RECORD_RETENTION_DAYS=30

# Payment providers — managed via Admin dashboard > System > Payment providers
# NOWPayments (crypto)
#   API key: create at https://account.nowpayments.io → API section
#   IPN secret: generate in Payment Settings tab (shown once — save it)
# RENDERSPHERE_NOWPAYMENTS_API_KEY=
# RENDERSPHERE_NOWPAYMENTS_IPN_SECRET=
# Optional NOWPayments tuning (sensible defaults shown):
# RENDERSPHERE_NOWPAYMENTS_DEFAULT_PAY_CURRENCY=btc
# RENDERSPHERE_NOWPAYMENTS_ALLOWED_PAY_CURRENCIES=btc,eth,usdt,usdc,dai,litecoin
# RENDERSPHERE_NOWPAYMENTS_FIAT_CURRENCY=USD
# RENDERSPHERE_NOWPAYMENTS_PREPAID_PACKAGES=crypto-10:10:USD:$10 credits,crypto-25:25:USD:$25 credits
# RENDERSPHERE_NOWPAYMENTS_CUSTOM_TOPUP_MIN_USD=5
# RENDERSPHERE_NOWPAYMENTS_CUSTOM_TOPUP_MAX_USD=500

# RunPod request tuning
RENDERSPHERE_RUNPOD_REQUEST_TIMEOUT_MS=15000
RENDERSPHERE_RUNPOD_STATUS_MAX_RETRIES=2
RENDERSPHERE_RUNPOD_CANCEL_MAX_RETRIES=1
RENDERSPHERE_RUNPOD_RETRY_BACKOFF_MS=300

# Observability
RENDERSPHERE_LOG_LEVEL=info
RENDERSPHERE_LOG_FORMAT=auto
RENDERSPHERE_REQUEST_LOGGING=true
RENDERSPHERE_PUBLIC_METRICS=false
RENDERSPHERE_RATE_LIMIT_REDIS_URL=
RENDERSPHERE_RATE_LIMIT_KEY_PREFIX=rendersphere
RENDERSPHERE_AUTH_RATE_LIMIT_WINDOW_MS=900000
RENDERSPHERE_AUTH_RATE_LIMIT_MAX=20
RENDERSPHERE_ACCOUNT_RATE_LIMIT_WINDOW_MS=3600000
RENDERSPHERE_ACCOUNT_RATE_LIMIT_MAX=20
RENDERSPHERE_RENDER_RATE_LIMIT_WINDOW_MS=60000
RENDERSPHERE_RENDER_RATE_LIMIT_MAX=12

# Limits
RENDERSPHERE_MAX_UPLOAD_MB=10240
RENDERSPHERE_MAX_RENDER_SAMPLES=2048
RENDERSPHERE_MAX_RESOLUTION_PCT=150
RENDERSPHERE_MAX_ANIMATION_FRAMES=250
RENDERSPHERE_MAX_CONCURRENT_JOBS=1
RENDERSPHERE_MAX_QUEUED_JOBS=3
RENDERSPHERE_JOB_RECORD_RETENTION_DAYS=30

# Smoke tests only
# SMOKE_TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rendersphere_smoke?schema=public"
