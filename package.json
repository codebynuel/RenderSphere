{
  "name": "rendersphere",
  "version": "1.0.0",
  "description": "RenderSphere gateway for cloud Blender rendering",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "lint:backend": "node scripts/check-backend-syntax.mjs",
    "db:check-isolated": "node scripts/check-isolated-database-url.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "prisma:validate": "prisma validate",
    "validate:env": "node scripts/validate-production-env.mjs",
    "frontend:install": "pnpm --dir frontend install --frozen-lockfile",
    "frontend:lint": "pnpm --dir frontend lint",
    "frontend:build": "pnpm --dir frontend build",
    "audit:root": "pnpm audit --prod --audit-level high",
    "audit:frontend": "pnpm --config.ignore-workspace=true --dir frontend audit --prod --audit-level high",
    "audit:release": "npm run audit:root && npm run audit:frontend",
    "docker:build:web": "docker build -f Dockerfile.web -t rendersphere-web:local .",
    "docker:build:worker": "docker build -f Dockerfile -t blender-runpod-worker:local .",
    "web:build": "npm run frontend:install && npm run frontend:build",
    "web:rebuild": "node scripts/rebuild-frontend.mjs",
    "web:fix-blank": "node scripts/rebuild-frontend.mjs",
    "release:prepare": "npm run db:generate && npm run web:build",
    "release:verify": "npm run lint:backend && npm run prisma:validate && npm run db:generate && npm run frontend:lint && npm run frontend:build && npm run package:extension:verify && npm run audit:release",
    "release:verify:db": "npm run db:check-isolated && npm run db:deploy && npm run db:status && npm run test",
    "package:extension": "node scripts/package-extension.mjs",
    "checksums:extension": "node scripts/checksum-extension.mjs",
    "checksums:extension:verify": "node scripts/checksum-extension.mjs --verify",
    "package:extension:verify": "npm run package:extension && npm run checksums:extension && npm run checksums:extension:verify",
    "test": "node scripts/smoke-test.mjs",
    "start:prod": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
