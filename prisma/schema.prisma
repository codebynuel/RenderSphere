generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  passwordHash      String
  passwordSalt      String
  starterBalanceUsd Float       @default(0.0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  accessKeys         AccessKey[]
  sessions           Session[]
  uploads            Upload[]
  jobs               Job[]
  projects           Project[]
  creditTransactions CreditTransaction[]
  creditAuditEvents  CreditAuditEvent[]
}

model AccessKey {
  id           String    @id @default(uuid())
  userId       String
  name         String?
  tokenHash    String    @unique
  tokenPreview String
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Upload {
  key           String   @id
  userId        String
  fileName      String
  fileSizeBytes BigInt
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Project {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      Job[]

  @@unique([userId, name])
  @@index([userId])
}

model Job {
  jobId             String    @id
  userId            String
  projectId         String?
  fileKey           String
  status            String    @default("SUBMITTED")
  settings          Json?
  progress          Json?
  frameCount        Int       @default(1)
  billableSeconds   Int       @default(0)
  resultKey         String?
  error             String?
  priceUsd          Float?
  pricePerSecondUsd Float?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  billedAt          DateTime?
  lastCheckedAt     DateTime?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creditTransactions CreditTransaction[]
  creditAuditEvents  CreditAuditEvent[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([projectId])
  @@index([status])
}

model CreditTransaction {
  id               String                @id @default(uuid())
  userId           String
  type             CreditTransactionType
  amountUsd        Decimal               @db.Decimal(12, 6)
  balanceBeforeUsd Decimal               @db.Decimal(12, 6)
  balanceAfterUsd  Decimal               @db.Decimal(12, 6)
  actorType        CreditActorType       @default(SYSTEM)
  actorId          String?
  actorEmail       String?
  referenceType    String?
  referenceId      String?
  jobId            String?
  idempotencyKey   String?               @unique
  metadata         Json?
  createdAt        DateTime              @default(now())

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job?                  @relation(fields: [jobId], references: [jobId], onDelete: SetNull)
  auditEvents      CreditAuditEvent[]

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([referenceType, referenceId])
  @@index([jobId])
}

model CreditAuditEvent {
  id                  String             @id @default(uuid())
  eventType           String
  targetUserId        String?
  actorType           CreditActorType    @default(SYSTEM)
  actorId             String?
  actorEmail          String?
  creditTransactionId String?
  jobId               String?
  referenceType       String?
  referenceId         String?
  idempotencyKey      String?
  metadata            Json?
  createdAt           DateTime           @default(now())

  targetUser          User?              @relation(fields: [targetUserId], references: [id], onDelete: SetNull)
  creditTransaction   CreditTransaction? @relation(fields: [creditTransactionId], references: [id], onDelete: SetNull)
  job                 Job?               @relation(fields: [jobId], references: [jobId], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([creditTransactionId])
  @@index([jobId])
  @@index([eventType, createdAt])
  @@index([referenceType, referenceId])
}

enum CreditTransactionType {
  CREDIT_GRANT
  PROMO_CREDIT
  PREPAID_TOP_UP
  RENDER_RESERVATION_HOLD
  RENDER_CHARGE
  REFUND
  RESERVATION_RELEASE
  ADMIN_ADJUSTMENT
}

enum CreditActorType {
  USER
  ADMIN
  SYSTEM
}
